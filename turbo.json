{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": [".env", ".env.example"],
  "globalEnv": [
    "NODE_ENV",
    "MOCK_PROVIDER",
    "MOCK_RESPONSE",
    "OPENAI_API_KEY",
    "ANTHROPIC_API_KEY",
    "GOOGLE_API_KEY",
    "OPENAI_MODEL",
    "ANTHROPIC_MODEL",
    "GOOGLE_MODEL",
    "PROVIDER_ORDER",
    "SESSION_SECRET",
    "DATABASE_URL",
    "OTEL_EXPORTER_OTLP_ENDPOINT",
    "OTEL_SERVICE_NAME",
    "OTEL_SERVICE_VERSION",
    "CONTEXT_MAX_TOKENS",
    "REDPANDA_BROKERS",
    "REDPANDA_TRACES_TOPIC"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    },
    "e2e": {
      "cache": false,
      "persistent": false
    }
  }
}
