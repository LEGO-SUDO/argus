# =============================================================================
# Argus Chatbot — environment variables.
# =============================================================================
# Copy to `.env` and edit. Defaults below let the entire stack boot end-to-end
# with zero external dependencies via the Mock provider (HLD D3 + PRD §Constraints).
# See README §Providers for the one-line swap to real keys.

# -----------------------------------------------------------------------------
# Provider selection
# -----------------------------------------------------------------------------
# When true (default), the SDK serves deterministic streamed tokens from the
# Mock adapter keyed by (conversationId, turnIndex). Set to `false` to enable
# the real provider router (OpenAI -> Anthropic -> Gemini failover, per HLD D3).
# When `false` AND no provider keys are set, the SDK throws
# `no_providers_configured` rather than silently falling back to mock.
MOCK_PROVIDER=true

# Provider API keys. Leave UNSET to disable that provider in the router.
# Router priority order is configurable via PROVIDER_ORDER below; default is
# OpenAI -> Anthropic -> Gemini.
# Leave unset to use mock provider.
OPENAI_API_KEY=
# Leave unset to use mock provider.
ANTHROPIC_API_KEY=
# Leave unset to use mock provider.
GOOGLE_API_KEY=

# Provider router priority. Comma-separated names; the SDK tries each in turn,
# failing over to the next when one errors BEFORE its first token. Unknown
# names are ignored. Default: openai,anthropic,gemini
# PROVIDER_ORDER=openai,anthropic,gemini

# Model overrides. Defaults are cheap+fast variants per provider; override to
# any model the provider supports. Pricing is in packages/sdk/src/cost.ts —
# unknown models cost-report as zero.
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-haiku-4-5
# GOOGLE_MODEL=gemini-3-flash-preview

# -----------------------------------------------------------------------------
# Auth / sessions (HLD D5: opaque session cookie, server-side sessions table)
# -----------------------------------------------------------------------------
# Used to sign session tokens. Generate locally with: openssl rand -hex 32
# DO NOT commit a real value. Leave blank in .env.example; the app refuses
# to boot in production mode with an empty SESSION_SECRET.
SESSION_SECRET=

# -----------------------------------------------------------------------------
# Database (HLD D4: Postgres via Prisma in packages/db)
# -----------------------------------------------------------------------------
# Default points at the compose `postgres` service; override for hosted Postgres.
DATABASE_URL=postgresql://argus:argus@postgres:5432/argus?schema=public

# -----------------------------------------------------------------------------
# Web -> API proxy
# -----------------------------------------------------------------------------
# Used by the Next web app to proxy browser requests from /api/* to the Nest API
# in production/server environments. Example for Vercel web + hosted API:
# INTERNAL_API_URL=https://your-api.example.com
INTERNAL_API_URL=http://api:4000

# -----------------------------------------------------------------------------
# Observability (HLD: OTLP/HTTP -> OTel Collector -> Redpanda + Jaeger)
# -----------------------------------------------------------------------------
# SDK + api + workers send OTLP spans here. The Collector fans out to Redpanda
# (for the projection consumer) and to Jaeger (for the trace-detail UI).
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
JAEGER_QUERY_URL=http://localhost:16686

# Optional: Sentry DSN for the workers process. Leave blank to disable.
SENTRY_DSN=

# -----------------------------------------------------------------------------
# Context window (HLD D6: last N turns, drop-oldest, no summarization)
# -----------------------------------------------------------------------------
# Default budget in tokens. ContextMeterService caps below this per pinned
# model's window (chat-context-and-ux-polish backbone). When unset, the
# apps/api defaults to 10000 — the PRD figure for the on-screen meter.
CONTEXT_TOKEN_BUDGET=10000

# -----------------------------------------------------------------------------
# Redpanda (HLD D1: `traces` topic keyed by message_id)
# -----------------------------------------------------------------------------
# Hybrid-dev (workers on host) connects via the EXTERNAL listener on
# localhost:19092 — the broker advertises this address so kafkajs can follow
# it after bootstrap. In-compose services use the INTERNAL listener at
# redpanda:9092 (hardcoded per-service in docker-compose.yml).
REDPANDA_BROKERS=localhost:19092
REDPANDA_TRACES_TOPIC=traces
