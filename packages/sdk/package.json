{
  "name": "@argus/sdk",
  "version": "0.0.0",
  "private": true,
  "description": "OTel-instrumented multi-provider LLM SDK (OpenAI, Anthropic, Gemini, Mock) with router + circuit breaker.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@argus/contracts": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "openai": "^6.39.0"
  },
  "devDependencies": {
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.6",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3"
  }
}
