{
  "name": "@argus/db",
  "version": "0.0.0",
  "private": true,
  "description": "Prisma schema + migrations + thin client wrapper for argus.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "prisma"],
  "scripts": {
    "build": "prisma generate && tsc --build",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest --passWithNoTests",
    "typecheck": "prisma generate && tsc --noEmit",
    "clean": "rm -rf dist .turbo node_modules prisma/generated",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.13.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.6",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "testcontainers": "^10.13.2",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3"
  }
}
